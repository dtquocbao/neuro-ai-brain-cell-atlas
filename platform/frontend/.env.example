# Used at Vercel build time to proxy /api/* to your HF Space (not embedded in the JS bundle).
# Local dev: leave empty — Vite proxies /api → localhost:8000
VITE_API_URL=

# Production (Vercel + GitHub Actions secret):
# VITE_API_URL=https://YOUR-USERNAME-neurovision-neuro-api.hf.space

# Google Analytics 4 (public measurement ID; baked into production builds via .env.production)
# VITE_GA_MEASUREMENT_ID=G-BLHJ2EERPW
